# Copy to .env and fill in. .env is gitignored.

# --- CTA GTFS-Realtime (the volume driver) ---
# Bus Tracker: https://www.transitchicago.com/developers/bustracker/
CTA_BUS_API_KEY=
# Train Tracker: https://www.transitchicago.com/developers/traintracker/
CTA_TRAIN_API_KEY=

# --- Chicago Data Portal (Socrata) ---
# Free app token lifts throttling for bulk pulls (congestion sxs8-h27x ~290M rows)
# https://evergreen.data.cityofchicago.org/profile/edit/developer_settings
SOCRATA_APP_TOKEN=

# --- Metra (optional, 2nd agency, added later) ---
METRA_GTFS_RT_USER=
METRA_GTFS_RT_PASS=

# --- Lake location (defaults to ./lake) ---
TRANSITLAKE_ROOT=./lake
